package org.lpu.dev;

import jakarta.annotation.PostConstruct;
import org.lpu.dev.model.data.User;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;
import org.springframework.stereotype.Component;

import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.hibernate.Transaction;

@Component
public class DatabaseSeeder {

	@Autowired
	private SessionFactory sessionFactory;

	private final BCryptPasswordEncoder encoder = new BCryptPasswordEncoder();

	public DatabaseSeeder() {
		System.out.println("=== DatabaseSeeder CREATED ===");
	}

	@PostConstruct
	public void seed() {
		System.out.println("=== DatabaseSeeder RUNNING ===");
		Session session = sessionFactory.openSession();
		Transaction tx = session.beginTransaction();

		try {

			// ❗ Check if admin already exists (avoid duplicates)
			Long count = (Long) session.createQuery("select count(u) from User u where u.username = :username")
					.setParameter("username", "admin").uniqueResult();

			if (count != null && count > 0) {
				System.out.println("Database already seeded.");
				return;
			}

			// 🔥 Seed users
			session.persist(createUser("cashier1", "1234", "Cashier Window 1", "TELLER"));
			session.persist(createUser("cashier2", "1234", "Cashier Window 2", "TELLER"));
			session.persist(createUser("registrar1", "1234", "Registrar Window 1", "TELLER"));
			session.persist(createUser("admin", "admin123", "System Admin", "ADMIN"));

			tx.commit();
			System.out.println("Database seeding completed.");

		} catch (Exception e) {
			tx.rollback();
			e.printStackTrace();
		} finally {
			session.close();
		}
	}

	private User createUser(String username, String password, String fullName, String role) {
		User user = new User();
		user.setUsername(username);
		user.setPasswordHash(encoder.encode(password)); // 🔥 REAL HASH
		user.setFullName(fullName);
		user.setRole(role);
		return user;
	}
}